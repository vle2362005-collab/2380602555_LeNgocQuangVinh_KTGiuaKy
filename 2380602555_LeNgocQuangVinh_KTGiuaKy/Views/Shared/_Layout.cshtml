@using System.Text.Json
@using _2380602555_LeNgocQuangVinh_KTGiuaKy.Models
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - _2380602555_LeNgocQuangVinh_KTGiuaKy</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/_2380602555_LeNgocQuangVinh_KTGiuaKy.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-dark border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand text-muted" asp-area="" asp-controller="Home" asp-action="Index">Test1</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-muted" asp-area="" asp-controller="SinhVien" asp-action="Index">Sinh Viên</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-muted" asp-area="" asp-controller="HocPhan" asp-action="ListHP">Học Phần</a>
                        </li>
                        <li class="nav-item">
                            @{
                                var gioHangJson = Context.Session.GetString("GioHang");
                                int count = 0;
                                if (!string.IsNullOrEmpty(gioHangJson))
                                {
                                    var cart = JsonSerializer.Deserialize<List<CartItem>>(gioHangJson);
                                    count = cart != null ? cart.Count : 0;
                                }
                            }
                            <a class="nav-link text-white fw-bold" asp-area="" asp-controller="GioHang" asp-action="GioHang">Đăng Kí (@count)</a>
                        </li>
                        <li class="nav-item">
                            @{
                                var userSession = Context.Session.GetString("HoTen");
                                if (!string.IsNullOrEmpty(userSession))
                                {
                                    <a class="nav-link text-muted" asp-controller="NguoiDung" asp-action="DangXuat">Xin chào @userSession (Đăng xuất)</a>
                                }
                                else
                                {
                                    <a class="nav-link text-muted" asp-controller="NguoiDung" asp-action="DangNhap">Đăng Nhập</a>
                                }
                            }
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - _2380602555_LeNgocQuangVinh_KTGiuaKy - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
