@{
    ViewData["Title"] = "Đăng Nhập";
}

<h2 class="mt-4 text-secondary text-uppercase mb-4">ĐĂNG NHẬP</h2>

<div class="row">
    <div class="col-md-6">
        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger">@ViewBag.Error</div>
        }

        <form asp-action="DangNhap" method="post">
            <div class="form-group row mb-4 align-items-center">
                <label class="col-sm-3 col-form-label fw-bold text-end">MaSV</label>
                <div class="col-sm-9">
                    <input type="text" name="MaSV" class="form-control" style="background-color: #e6f0ff; border-color: #b3d4ff;" required />
                </div>
            </div>

            <div class="form-group row">
                <div class="col-sm-3"></div>
                <div class="col-sm-9">
                    <input type="submit" value="Đăng Nhập" class="btn btn-outline-secondary px-4" />
                </div>
            </div>
        </form>
    </div>
</div>

<div class="mt-4 border-top pt-3 text-muted">
    <a asp-action="Index" asp-controller="SinhVien" class="text-decoration-none">Back to List</a>
</div>